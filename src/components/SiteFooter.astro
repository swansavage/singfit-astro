---
import { CALENDLY_URL, FOOTER_LEGAL_LINKS } from '../data/site';
import CtaLink from './ui/CtaLink.astro';
import LogoLockup from './ui/LogoLockup.astro';
---

<footer class="footer">
  <LogoLockup variant="footer" />
  <p class="footer-legal">
    ©2026 Musical Health Technologies. All Rights Reserved.<br>
    1010 Wilshire Blvd. Los Angeles, CA 90017
  </p>

  <nav class="footer-links" aria-label="Footer navigation">
    {FOOTER_LEGAL_LINKS.map((link) => (
      <a href={link.href} target={link.target} rel={link.rel}>{link.label}</a>
    ))}
  </nav>

  <div class="footer-cta">
    <CtaLink label="Free Walkthrough" href={CALENDLY_URL} variant="primary" />
    <p>Talk with the SingFit team. No obligation.</p>
  </div>
</footer>
