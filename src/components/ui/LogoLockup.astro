---
import singfitLogo from '../../assets/brand/asset-01.png';
import { PRODUCT_DESCRIPTOR } from '../../data/site';

interface Props {
  variant?: 'default' | 'footer';
}

const { variant = 'default' } = Astro.props;
const className = variant === 'footer' ? 'brand logo-brand footer-logo-brand' : 'brand logo-brand';
---

<div class={className}>
  <img class="singfit-logo-img" src={singfitLogo.src} alt="SingFit">
  <span class="brand-product">{PRODUCT_DESCRIPTOR}</span>
</div>
