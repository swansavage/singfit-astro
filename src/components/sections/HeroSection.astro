---
import heroCaregiverPhoto from '../../assets/hero/Fixed Laina Testimonial Image.png';
import studioControlsDevice from '../../assets/hero/asset-05.png';
import { CALENDLY_URL } from '../../data/site';
import CtaLink from '../ui/CtaLink.astro';
---

<section class="hero">
  <div>
    <h1>Guided singing for dementia and memory care.</h1>
    <p class="hero-copy">
      SingFit STUDIO Caregiver helps family caregivers sing familiar songs together with someone living with dementia, memory loss, or cognitive decline using lyric coaching, guide vocals, and built-in prompts.
    </p>

    <div class="actions">
      <CtaLink label="Talk with the SingFit Team" href={CALENDLY_URL} variant="primary" />
      <CtaLink label="See a session" href="#video" variant="secondary" />
    </div>

    <p class="microcopy">Free 20-minute conversation about your caregiving routine and how SingFit may fit into it. No obligation.</p>
  </div>

  <div class="hero-visual">
    <div class="hero-stage">
      <div class="hero-image-panel">
        <div class="hero-image-art hero-photo-art">
          <img src={heroCaregiverPhoto.src} alt="Two women smiling at each other beside a tablet during a SingFit session">
        </div>
      </div>

      <div class="iphone hero-phone-image">
        <img src={studioControlsDevice.src} alt="SingFit STUDIO controls showing Lyric Coach, Guide Singer, Your Voice, and playback speed">
      </div>
    </div>
  </div>
</section>

<style>


.hero{
  display:grid;
  grid-template-columns:minmax(0,.84fr) minmax(640px,1.16fr);
  gap:clamp(44px, 5vw, 84px);
  align-items:center;
  max-width:1280px;
  margin-inline:auto;
  padding:clamp(40px,6vw,96px) var(--site-padding) clamp(72px,8vw,104px);
}

.hero h1{
  max-width:15.5ch;
  font-size:clamp(44px, 7vw, 82px);
  line-height:.95;
}

.hero-copy{
  max-width:36rem;
  margin-top:24px;
  color:var(--ink-soft);
  font-size:clamp(18px, 1.9vw, 21px);
  line-height:1.68;
}

.actions{
  display:flex;
  flex-wrap:wrap;
  gap:14px;
  margin-top:30px;
}

.hero-visual{
  position:relative;
  width:100%;
  max-width:780px;
  min-height:640px;
  margin-left:auto;
}

.hero-stage{
  position:relative;
  width:100%;
  min-height:inherit;
  overflow:visible;
}

.hero-image-panel{
  position:absolute;
  left:0;
  right:72px;
  top:56px;
  bottom:82px;
  overflow:hidden;
  border-radius:42px;
  background:rgba(255,255,255,.62);
  border:1px solid rgba(255,255,255,.78);
  box-shadow:0 22px 60px rgba(23,33,43,.10);
  backdrop-filter:blur(12px);
}

.hero-image-art{
  position:absolute;
  inset:16px;
  overflow:hidden;
  border-radius:32px;
  background:
    radial-gradient(circle at 22% 18%,rgba(255,255,255,.48),transparent 20%),
    radial-gradient(circle at 84% 82%,rgba(44,166,161,.08),transparent 22%),
    linear-gradient(135deg,#edd1c0 0%,#efe0d0 42%,#ddeae7 100%);
}

.hero-photo-art{background:none}

.hero-photo-art img{
  width:100%;
  height:100%;
  min-height:inherit;
  object-fit:cover;
  object-position:52% center;
  border-radius:inherit;
}

.hero-phone-image{
  position:absolute;
  right:-58px;
  bottom:-34px;
  z-index:18;
  width:clamp(280px, 28vw, 360px);
  padding:0;
  background:transparent;
  border-radius:0;
  box-shadow:none;
  pointer-events:none;
}

.hero-phone-image img{
  display:block;
  width:100%;
  height:auto;
  filter:drop-shadow(0 24px 42px rgba(15,23,42,.24));
}

@media (min-width:1320px){
  .hero{
    padding-left:40px;
    padding-right:40px;
  }
}

@media (max-width:1120px){

  .hero{
    grid-template-columns:1fr;
    gap:42px;
  }

  .hero-visual{
    max-width:860px;
    min-height:580px;
    margin-inline:auto;
  }

  .hero-stage{
    min-height:580px;
  }

  .hero-image-panel{
    right:68px;
    top:52px;
    bottom:74px;
    border-radius:36px;
  }

  .hero-image-art{
    inset:14px;
    border-radius:28px;
  }

  .hero-photo-art img{
    object-position:50% center;
  }

  .hero-phone-image{
    right:-42px;
    bottom:-28px;
    width:clamp(250px, 34vw, 330px);
  }
}

@media (max-width:720px){

  .hero-copy{
    font-size:18px;
  }

  .hero{
    gap:34px;
  }

  .hero-visual{
    min-height:480px;
  }

  .hero-stage{
    min-height:480px;
  }

  .hero-image-panel{
    right:42px;
    top:40px;
    bottom:66px;
    border-radius:28px;
  }

  .hero-image-art{
    inset:12px;
    border-radius:22px;
  }

  .hero-photo-art img{
    object-position:54% center;
  }

  .hero-phone-image{
    right:-24px;
    bottom:-12px;
    width:clamp(220px, 52vw, 320px);
  }
}

@media (max-width:560px){

  .hero-visual{
    min-height:430px;
  }

  .hero-stage{
    min-height:430px;
  }

  .hero-image-panel{
    right:30px;
    top:34px;
    bottom:58px;
    border-radius:24px;
  }

  .hero-image-art{
    inset:10px;
    border-radius:18px;
  }

  .hero-photo-art img{
    object-position:55% center;
  }

  .hero-phone-image{
    right:-18px;
    bottom:-8px;
    width:clamp(190px, 54vw, 260px);
  }
}

@media (max-width:420px){
  .hero-visual{
    min-height:395px;
  }

  .hero-stage{
    min-height:395px;
  }

  .hero-image-panel{
    right:24px;
    top:30px;
    bottom:54px;
  }

  .hero-phone-image{
    width:clamp(170px, 55vw, 230px);
  }
}
</style>
