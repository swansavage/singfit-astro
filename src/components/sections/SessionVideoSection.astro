---
import { SECTION_CTAS } from '../../data/landing-page';
import { VIMEO_SESSION } from '../../data/site';
import SectionCta from '../ui/SectionCta.astro';
---

<section class="section" id="video">
  <div class="video-panel">
    <div>
      <h2>See what a guided sing-along looks like.</h2>
      <p class="lead">
        Watch a short walkthrough of SingFit STUDIO Caregiver and see how lyric coaching, guide vocals, and conversation prompts turn familiar songs into something you can do together.
      </p>
    </div>

    <div class="video-box video-embed">
      <iframe
        src={VIMEO_SESSION.embedUrl}
        title={VIMEO_SESSION.title}
        loading="lazy"
        referrerpolicy="strict-origin-when-cross-origin"
        allow="fullscreen; picture-in-picture; clipboard-write; encrypted-media"
        allowfullscreen>
      </iframe>
      <noscript>
        <p><a href={VIMEO_SESSION.fallbackUrl}>Watch the SingFit session video on Vimeo</a></p>
      </noscript>
    </div>
  </div>
  <SectionCta {...SECTION_CTAS.sessionVideo} />
</section>

<style>


.video-panel{
  display:grid;
  grid-template-columns:minmax(0,.88fr) minmax(0,1.12fr);
  gap:clamp(24px, 4vw, 42px);
  align-items:center;
  padding:clamp(22px, 3vw, 36px);
  border-radius:46px;
  background:#fff;
  border:1px solid var(--line);
  box-shadow:var(--soft-shadow);
}

.video-box{
  position:relative;
  min-height:clamp(270px, 34vw, 410px);
  display:grid;
  place-items:center;
  overflow:hidden;
  border-radius:36px;
  background:
    radial-gradient(circle at 24% 24%,rgba(255,255,255,.16),transparent 30%),
    linear-gradient(135deg,#176d72,#249f9a);
}

.video-embed{
  display:block;
  position:relative;
  min-height:0;
  aspect-ratio:16 / 9;
  background:#0f2e38;
}

.video-embed::after{display:none}

.video-embed iframe{
  position:absolute;
  inset:0;
  width:100%;
  height:100%;
  border:0;
  border-radius:inherit;
}

@media (max-width:920px){

  .video-panel{
    grid-template-columns:1fr;
  }
}

@media (max-width:560px){

  .video-embed{
    min-height:0;
    aspect-ratio:16 / 9;
  }
}
</style>
