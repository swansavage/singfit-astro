---
import { FAQS } from '../../data/landing-page';
---

<section class="section center" id="questions">
  <h2>Questions before you begin.</h2>

  <div class="faq">
    {FAQS.map((faq) => (
      <div class="faq-row">
        <h3>{faq.question}</h3>
        <p>{faq.answer}</p>
      </div>
    ))}
  </div>
</section>

<style>


.faq{
  max-width:900px;
  margin:34px auto 0;
  border-top:1px solid var(--line);
  text-align:left;
}

.faq-row{
  display:grid;
  grid-template-columns:minmax(0,.42fr) minmax(0,.58fr);
  gap:24px;
  padding:24px 0;
  border-bottom:1px solid var(--line);
}

.faq-row h3{
  font-size:clamp(22px, 2.4vw, 25px);
  line-height:1.12;
}

@media (max-width:920px){

  .faq-row{
    grid-template-columns:1fr;
    gap:12px;
  }
}
</style>
