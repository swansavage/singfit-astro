---
import { Image } from 'astro:assets';
import audienceCaregiverPhoto from '../../assets/audience/E_YpTUiw.jpeg';
import { AUDIENCE_SITUATIONS, SECTION_CTAS } from '../../data/landing-page';
import ProductPhoneVideo from '../ui/ProductPhoneVideo.astro';
import SectionCta from '../ui/SectionCta.astro';
---

<section class="section who-redesign" id="who">
  <div class="who-situation-layout">
    <div class="who-intro">
      <h2>Some days, it is hard to know what to do together.</h2>
      <p class="lead">
        STUDIO Caregiver is designed for family caregivers supporting an older loved one when conversation or shared activities feel harder than they used to. It gives you a guided way to sing familiar songs together instead of wondering what to do next.
      </p>
    </div>

    <div class="who-image-panel">
      <div class="who-image-stage">
        <div class="who-real-image-panel">
          <Image
            src={audienceCaregiverPhoto}
            alt="A caregiver and older loved one singing together while listening and following along with SingFit"
            width={1560}
            widths={[360, 720, 1080, 1560]}
            sizes="(max-width: 560px) calc(100vw - 85px), (max-width: 920px) calc(100vw - 140px), 460px"
            format="webp"
            quality={88}
            loading="lazy"
            decoding="async"
          />
        </div>

        <ProductPhoneVideo
          src="/media/screen-capture2.mp4"
          ariaLabel="Preview of the SingFit STUDIO Caregiver Lyric Coach experience"
          variant="floating"
        />
      </div>
    </div>

    <div class="who-situation-list">
      {AUDIENCE_SITUATIONS.map((situation) => (
        <div class="who-situation">
          <span>{situation.number}</span>
          <div>
            <h3>{situation.heading}</h3>
            <p>{situation.body}</p>
          </div>
        </div>
      ))}
    </div>
  </div>

  <SectionCta {...SECTION_CTAS.audience} variant="audience" />
</section>

<style>


.who-situation-layout{
  display:grid;
  grid-template-columns:minmax(0,.9fr) minmax(0,1.1fr);
  grid-template-areas:
    "image intro"
    "image list";
  gap:clamp(24px, 4vw, 42px);
  align-items:start;
}

.who-intro{
  grid-area:intro;
  max-width:none;
  margin-bottom:0;
}

.who-image-panel{
  grid-area:image;
  min-height:clamp(380px, 48vw, 620px);
  overflow:visible;
}

.who-image-stage{
  position:relative;
  min-height:inherit;
  padding:0 0 clamp(70px, 8vw, 106px) clamp(10px, 1.6vw, 18px);
  overflow:visible;
}

.who-situation-list{
  grid-area:list;
  display:grid;
  gap:6px;
  align-content:start;
}

.who-situation{
  display:grid;
  grid-template-columns:52px minmax(0,1fr);
  gap:18px;
  padding:22px 0;
  border-bottom:1px solid var(--line);
}

.who-situation:first-child{
  border-top:1px solid var(--line);
}

.who-situation > span{
  width:38px;
  height:38px;
  border-radius:999px;
  display:grid;
  place-items:center;
  background:#fff1e4;
  color:var(--orange);
  font-size:13px;
  font-weight:700;
}

.who-situation h3{
  font-size:clamp(24px, 3.2vw, 30px);
  line-height:1.08;
}

.who-situation p{
  margin-top:10px;
  max-width:35rem;
}

:global(.product-phone.product-phone-floating){
  position:absolute;
  left:0;
  bottom:0;
  z-index:3;
  width:clamp(170px, 34%, 222px);
  transform:translate(-6%, 11%) rotate(-1.8deg);
}

@media (max-width:920px){

  .who-situation-layout{
    grid-template-columns:1fr;
    grid-template-areas:
      "intro"
      "image"
      "list";
  }

  .who-image-stage{
    padding-left:0;
    padding-bottom:78px;
  }

  :global(.product-phone.product-phone-floating){
    left:18px;
    width:clamp(154px, 30vw, 198px);
    transform:translateY(10%) rotate(-1.5deg);
  }
}

@media (max-width:720px){

  .who-image-panel{
    min-height:auto;
  }

  .who-image-stage{
    min-height:0;
    padding-bottom:62px;
  }

  .who-real-image-panel{
    padding:14px;
    border-radius:32px;
  }

  .who-real-image-panel{
    min-height:clamp(280px, 82vw, 380px);
  }

  .who-real-image-panel > img{
    border-radius:22px;
  }

  .who-real-image-panel > img{
    object-position:50% center;
  }

  :global(.product-phone.product-phone-floating){
    left:16px;
    width:clamp(104px, 27vw, 140px);
    transform:translateY(6%) rotate(-1.25deg);
  }
}

@media (max-width:560px){

  .who-real-image-panel{
    padding:12px;
    border-radius:28px;
  }

  .who-real-image-panel > img{
    border-radius:20px;
  }

  .who-real-image-panel > img{
    object-position:50% center;
  }

  .who-image-stage{
    padding-bottom:56px;
  }

  :global(.product-phone.product-phone-floating){
    left:10px;
    width:min(31vw, 126px);
    transform:translateY(4%) rotate(-1deg);
  }
}
</style>
